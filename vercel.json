{
  "headers": [
    {
      "source": "/api/roku-feed",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=300, stale-while-revalidate=60" }
      ]
    },
    {
      "source": "/api/data-config",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=3600, stale-while-revalidate=300" }
      ]
    },
    {
      "source": "/api/generate-laurel-svg",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=86400" }
      ]
    },
    {
      "source": "/api/robots",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=86400" }
      ]
    }
  ],
  "functions": {
    "api/roku-feed.ts": {
      "maxDuration": 30
    }
  }
}
