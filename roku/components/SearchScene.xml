<?xml version="1.0" encoding="utf-8" ?>
<!--
    CRATE TV - Search Scene
    Left: A-Z keyboard
    Right: PosterGrid (5 col x 2 row) -- clean, no overlap, native Roku focus
    UP from top row fires exitRequested -> top nav bar
-->
<component name="SearchScene" extends="Group">
    <interface>
        <field id="feedData" type="node" onChange="OnFeedDataReady" />
        <field id="playContent" type="node" alwaysNotify="true" />
        <field id="exitRequested" type="boolean" value="false" alwaysNotify="true" />
        <field id="showActorDetail" type="string" value="" alwaysNotify="true" />
    </interface>

    <script type="text/brightscript" uri="pkg:/source/Config.brs" />
    <script type="text/brightscript" uri="pkg:/source/ResolutionManager.brs" />
    <script type="text/brightscript" uri="pkg:/source/Utils.brs" />
    <script type="text/brightscript" uri="SearchScene.brs" />

    <children>
        <Rectangle width="1920" height="1080" color="#050505" />

        <!-- Mobile keyboard bridge (Hulu/Netflix pattern) -->
        <TextEditBox id="mobileTextBox"
            translation="[0, 1100]" width="1" height="1" opacity="0.0" />

        <!-- LEFT: search bar + A-Z keyboard -->
        <Group id="leftPanel" translation="[60, 30]">
            <Rectangle width="620" height="56" color="#1A1A1A" />
            <Rectangle width="4" height="56" color="#EF4444" />
            <Label id="searchInput" text=""
                   font="font:MediumBoldSystemFont" color="#EBEBEB"
                   translation="[18, 13]" width="580" />
            <Label id="searchPlaceholder"
                   text="Search movies, directors, actors..."
                   font="font:SmallSystemFont" color="#555555"
                   translation="[18, 18]" width="580" />
            <Label id="mobileHint"
                   text=""
                   font="font:SmallSystemFont" color="#666666"
                   translation="[18, 42]" width="580" visible="false" />
            <Rectangle id="searchCursor" width="2" height="28"
                       color="#EF4444" translation="[18, 14]" visible="true" />
            <Group id="keyboardGroup" translation="[0, 70]">
                <LayoutGroup id="keyboardGrid"
                             layoutDirection="vert" itemSpacings="[8]" />
            </Group>
        </Group>

        <!-- Subtle divider -->
        <Rectangle width="1" height="980" color="#1A1A1A" translation="[728, 20]" />

        <!-- RIGHT: results label + PosterGrid -->
        <Group id="resultsGroup" translation="[748, 30]">
            <Rectangle width="4" height="26" color="#EF4444" translation="[0, 4]" />
            <Label id="resultsLabel" text="Top Movies"
                   font="font:MediumBoldSystemFont" color="#EBEBEB"
                   translation="[14, 0]" />

            <!--
                PosterGrid: 5 cols x 2 rows = 10 results visible at once.
                Native Roku component -- no overlap, no custom rendering bugs.
                focusBitmapUri = our red rounded ring PNG.
                UP from row 0 caught in BRS -> exitRequested -> top nav.
            -->
            <PosterGrid
                id="resultsGrid"
                translation="[0, 44]"
                basePosterSize="[200, 300]"
                numColumns="5"
                numRows="2"
                itemSpacing="[16, 24]"
                drawFocusFeedback="true"
                drawFocusFeedbackOnTop="true"
                focusBitmapUri="pkg:/images/focus_ring_red_208x308.png"
                vertFocusAnimationStyle="floatingFocus"
                visible="true"
            />

            <Label id="noResultsLabel" text="No results found."
                   font="font:MediumSystemFont" color="#444444"
                   translation="[380, 300]" visible="false" />

            <!-- Actor info panel (overlays grid on actor focus) -->
            <Group id="actorPanel" translation="[0, 44]" visible="false">
                <Rectangle width="1140" height="420" color="#111111" opacity="0.97" />
                <Rectangle width="4" height="420" color="#EF4444" />
                <Poster id="actorPanelPhoto" translation="[20, 20]"
                        width="180" height="270" loadDisplayMode="scaleToFit" />
                <Label id="bioScrollUp"   text="" font="font:SmallSystemFont"
                       color="#EF4444" translation="[1100, 8]" visible="false" />
                <Label id="bioScrollDown" text="" font="font:SmallSystemFont"
                       color="#EF4444" translation="[1100, 398]" visible="false" />
                <Group translation="[220, 20]">
                    <Label id="actorPanelName" text=""
                           font="font:LargeBoldSystemFont" color="#EBEBEB"
                           width="880" maxLines="1" />
                    <Rectangle width="880" height="2" color="#EF4444"
                               translation="[0, 60]" />
                    <Label id="actorPanelBio" text=""
                           font="font:SmallSystemFont" color="#CCCCCC"
                           width="880" maxLines="16" wrap="true"
                           translation="[0, 72]" />
                </Group>
            </Group>
        </Group>
    </children>
</component>
