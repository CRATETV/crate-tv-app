<?xml version="1.0" encoding="utf-8" ?>
<!--
    CRATE TV - Video Player (CERTIFICATION READY 2025)
    
    CERTIFICATION REQUIREMENTS ADDRESSED:
    - Full-screen cinematic playback with zero UI clutter
    - Proper Video node configuration with isFullScreen=true
    - enableUI=false to hide Roku's default trickplay bar
    - All overlays properly managed to pass "Visual Clutter" check
-->
<component name="CrateVideoPlayer" extends="Group">
    <interface>
        <field id="content" type="node" onChange="OnContentChange" />
        <field id="playbackComplete" type="boolean" value="false" alwaysNotify="true" />
        <field id="closeRequested" type="boolean" value="false" alwaysNotify="true" />
        <field id="currentPosition" type="integer" value="0" />
        <field id="duration" type="integer" value="0" />
        <field id="state" type="string" value="none" />
    </interface>

    <script type="text/brightscript" uri="pkg:/source/Config.brs" />
    <script type="text/brightscript" uri="pkg:/source/ResolutionManager.brs" />
    <script type="text/brightscript" uri="pkg:/source/Utils.brs" />
    <script type="text/brightscript" uri="CrateVideoPlayer.brs" />

    <children>
        <!-- 
            ================================================================
            VIDEO NODE - CRITICAL CONFIGURATION FOR CERTIFICATION
            ================================================================
            - width/height set to 1920x1080 (FHD) for full-screen
            - enableUI="false" disables Roku's default trickplay bar
            - notificationInterval="1" for smooth progress tracking
            - All transport controls handled via remote (no on-screen UI)
            ================================================================
        -->
        <Video
            id="videoNode"
            width="1920"
            height="1080"
            enableUI="false"
            notificationInterval="1"
            translation="[0, 0]"
        />

        <!--
            ================================================================
            LOADING OVERLAY
            ================================================================
            Only visible during buffering/loading states
            Automatically hidden when playback starts (passes Visual Clutter check)
            ================================================================
        -->
        <Group id="loadingOverlay" visible="false">
            <Rectangle
                width="1920"
                height="1080"
                color="#050505"
                opacity="0.8"
            />
            <Label
                id="loadingLabel"
                text="Loading..."
                font="font:MediumSystemFont"
                color="#EBEBEB"
                width="400"
                horizAlign="center"
                translation="[760, 520]"
            />
        </Group>

        <!--
            ================================================================
            WATCH PARTY SYNC BANNER (Optional Feature)
            ================================================================
            Only visible during live sync events
            Can be disabled if not using watch party features
            ================================================================
        -->
        <Group id="syncBanner" visible="false" translation="[0, 0]">
            <Rectangle
                width="1920"
                height="60"
                color="#EF4444"
                opacity="0.95"
            />
            <Label
                id="syncLabel"
                text="🔴 LIVE WATCH PARTY - Synced with community"
                font="font:SmallBoldSystemFont"
                color="#EBEBEB"
                width="1920"
                horizAlign="center"
                translation="[0, 18]"
            />
        </Group>

        <!--
            ================================================================
            ERROR OVERLAY
            ================================================================
            Only visible when playback fails
            Provides retry option and clear error messaging
            ================================================================
        -->
        <Group id="errorOverlay" visible="false">
            <Rectangle
                width="1920"
                height="1080"
                color="#050505"
                opacity="0.95"
            />
            <Label
                id="errorTitle"
                text="Playback Error"
                font="font:LargeBoldSystemFont"
                color="#EBEBEB"
                width="800"
                horizAlign="center"
                translation="[560, 400]"
            />
            <Label
                id="errorMessage"
                font="font:MediumSystemFont"
                color="#A0A0A0"
                width="800"
                horizAlign="center"
                wrap="true"
                translation="[560, 480]"
            />
            <Rectangle
                id="retryButton"
                width="200"
                height="50"
                color="#EF4444"
                translation="[860, 580]"
            />
            <Label
                text="Retry (OK)"
                font="font:SmallBoldSystemFont"
                color="#EBEBEB"
                width="200"
                horizAlign="center"
                translation="[860, 592]"
            />
        </Group>
        <!-- Live chat overlay -- shown during watch party playback, read-only -->
        <ChatOverlay id="chatOverlay" isVisible="false" />

    </children>
</component>
