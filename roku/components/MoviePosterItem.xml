<?xml version="1.0" encoding="utf-8" ?>
<!--
    CRATE TV - Movie Poster Item (V4 Studio)
    
    CRATE STANDARD: Poster [240, 360] / Focus Ring [248, 368] @ [-4, -4]
    CLEAN UI: No "Press OK" labels. No title text on poster.
    FOCUS: Red rounded focus ring PNG + 1.1x scale transform.
    ROUNDED: corner_mask overlay creates rounded poster corners.
    SMART SIZING: Dynamically adjusts all elements based on width/height fields.
    RowList auto-sets itemContent when scrolling.
-->
<component name="MoviePosterItem" extends="Group">
    <interface>
        <field id="itemContent" type="node" onChange="OnContentChange" />
        <field id="focusPercent" type="float" value="0.0" onChange="OnFocusChange" />
        <field id="rowFocusPercent" type="float" value="0.0" />
        <field id="itemHasFocus" type="boolean" value="false" />
        <field id="width" type="float" value="240" />
        <field id="height" type="float" value="360" />
    </interface>

    <script type="text/brightscript" uri="MoviePosterItem.brs" />

    <children>
        <Group id="posterContainer">
            <!-- Shadow -->
            <Rectangle id="shadow" width="244" height="364" color="#000000" opacity="0.4" translation="[4, 6]" />

            <!-- Background -->
            <Rectangle id="posterBg" width="240" height="360" color="#1A1A1A" />

            <!-- Shimmer loading state -->
            <Rectangle id="shimmerBase" width="240" height="360" color="#252525" />
            <Rectangle id="shimmerBar"  width="240" height="360" color="#333333" opacity="0.0" />

            <!-- Poster image -->
            <Poster id="posterImage" width="240" height="360"
                    loadWidth="240" loadHeight="360" loadDisplayMode="limitSize"
                    loadingBitmapOpacity="0.0"
                    failedBitmapUri="pkg:/images/poster_placeholder.png" />

            <!-- Lock overlay -->
            <Group id="lockOverlay" visible="false">
                <Rectangle id="lockOverlayRect" width="240" height="360" color="#000000" opacity="0.55" />
                <!-- Lock icon: red pill badge at bottom -->
                <Rectangle width="240" height="52" color="#EF4444" opacity="0.95" translation="[0, 308]" />
                <Label id="lockOverlayLabel" text="PREMIERE" font="font:SmallBoldSystemFont" color="#FFFFFF" width="240" height="52" horizAlign="center" vertAlign="center" translation="[0, 308]" />
                <!-- Lock shackle (top arc approximated with rectangles) -->
                <Rectangle width="30" height="5" color="#FFFFFF" translation="[105, 120]" />
                <Rectangle width="5" height="22" color="#FFFFFF" translation="[105, 120]" />
                <Rectangle width="5" height="22" color="#FFFFFF" translation="[130, 120]" />
                <!-- Lock body -->
                <Rectangle width="40" height="30" color="#FFFFFF" translation="[100, 138]" />
                <!-- Keyhole -->
                <Rectangle width="10" height="10" color="#EF4444" translation="[115, 143]" />
                <Rectangle width="6" height="10" color="#EF4444" translation="[117, 152]" />
            </Group>

            <!-- Watch progress bar -->
            <Group id="progressGroup" visible="false" translation="[0, 352]">
                <Rectangle id="progressBg" width="240" height="8" color="#333333" />
                <Rectangle id="progressFill" width="0" height="8" color="#EF4444" />
            </Group>

            <!-- Rounded corner mask -- cuts poster into rounded rect shape -->
            <Poster id="cornerMask" width="240" height="360"
                    uri="pkg:/images/corner_mask_240x360.png" />

            <!-- Rank badge (Top Ten only) -- bottom-left corner -->
            <Group id="rankBadge" visible="false">
                <Rectangle id="rankBadgeBg" width="56" height="56" color="#EF4444" opacity="0.92" translation="[0, 304]" />
                <Label id="rankBadgeLabel" text="" font="font:BoldSystemFont" color="#FFFFFF"
                       width="56" height="56" horizAlign="center" vertAlign="center"
                       translation="[0, 304]" />
            </Group>

            <!-- Red rounded focus ring (PNG) -- visible only when focused -->
            <Poster id="focusBorder" width="248" height="368"
                    uri="pkg:/images/focus_ring_red_248x368.png"
                    translation="[-4, -4]"
                    visible="false" />
        </Group>
    </children>
</component>
