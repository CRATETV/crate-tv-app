<?xml version="1.0" encoding="utf-8" ?>
<component name="VideoPlayer" extends="Group">
    <interface>
        <field id="content" type="node" onChange="onContentChange" />
        <field id="state" type="string" />
        <!-- Buffering Status Monitor for Requirement 3.6 -->
        <field id="bufferingStatus" type="assocarray" />
        <field id="command" type="assocarray" alwaysNotify="true" />
    </interface>
    <script type="text/brightscript" uri="pkg:/components/VideoPlayer.brs" />
    <children>
        <Rectangle width="1920" height="1080" color="0x000000FF" />
        <Video id="video" width="1920" height="1080" visible="false" transportBarVisible="false" />
        
        <!-- Paywall Overlay -->
        <Group id="paywall" visible="false">
            <Rectangle width="1920" height="1080" color="0x000000CC" />
            <Label text="PREMIUM ACCESS REQUIRED" translation="[0, 300]" width="1920" horizAlign="center" font="font:LargeBoldSystemFont" color="0xEF4444FF" />
            <Label id="priceLabel" text="Unlock this film on cratetv.net" translation="[0, 400]" width="1920" horizAlign="center" font="font:MediumSystemFont" />
            
            <Rectangle width="220" height="220" translation="[850, 480]" color="#FFFFFF" radius="10">
                <Poster id="qrCode" width="200" height="200" translation="[10, 10]" />
            </Rectangle>
            
            <Label text="Scan to unlock or create an account" translation="[0, 720]" width="1920" horizAlign="center" font="font:SmallSystemFont" color="#AAAAAA" />
            
            <Rectangle id="buyBtn" translation="[810, 800]" width="300" height="80" color="0xFFFFFFFF" radius="10">
                <Label text="CLOSE" width="300" height="80" horizAlign="center" vertAlign="center" color="0x000000FF" font="font:SmallBoldSystemFont" />
            </Rectangle>
        </Group>
    </children>
</component>