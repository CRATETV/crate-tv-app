<?xml version="1.0" encoding="utf-8" ?>
<!--
    CRATE TV - Details Scene (V4 Studio)
    Content details with:
    - HD backdrop
    - Full metadata display
    - Cast & Director lists
    - Play button (or QR paywall for locked content)
-->
<component name="DetailsScene" extends="Group">
    <interface>
        <field id="content" type="node" onChange="OnContentSet" />
        <field id="playRequested" type="boolean" value="false" alwaysNotify="true" />
        <field id="closeRequested" type="boolean" value="false" alwaysNotify="true" />
    </interface>

    <script type="text/brightscript" uri="pkg:/source/Config.brs" />
    <script type="text/brightscript" uri="pkg:/source/ResolutionManager.brs" />
    <script type="text/brightscript" uri="DetailsScene.brs" />

    <children>
        <!-- Full-screen backdrop -->
        <Poster
            id="backdrop"
            width="1920"
            height="1080"
            loadingBitmapOpacity="0.0"
            failedBitmapOpacity="0.0"
        />

        <!-- Dark overlay -->
        <Rectangle
            id="darkOverlay"
            width="1920"
            height="1080"
            color="#050505"
            opacity="0.7"
        />

        <!-- Left panel gradient -->
        <Rectangle
            id="leftPanel"
            width="850"
            height="1080"
            color="#050505"
            opacity="0.95"
        />

        <!-- Content area -->
        <Group id="contentArea" translation="[90, 80]">
            <!-- Back hint -->
            <Label
                id="backHint"
                text="‹ Back"
                font="font:SmallSystemFont"
                color="#666666"
            />

            <!-- Title -->
            <Label
                id="titleLabel"
                font="font:LargeBoldSystemFont"
                color="#EBEBEB"
                width="700"
                maxLines="2"
                wrap="true"
                translation="[0, 60]"
            />

            <!-- Metadata row -->
            <LayoutGroup
                id="metaRow"
                layoutDirection="horiz"
                itemSpacings="[15]"
                translation="[0, 170]"
            >
                <Label id="yearLabel" font="font:SmallBoldSystemFont" color="#A0A0A0" />
                <Rectangle id="ratingBadge" height="26" color="#333333" visible="false">
                    <Label id="ratingLabel" font="font:SmallestBoldSystemFont" color="#EBEBEB" translation="[8, 4]" />
                </Rectangle>
                <Label id="durationLabel" font="font:SmallSystemFont" color="#A0A0A0" />
            </LayoutGroup>

            <!-- Genres -->
            <Label
                id="genresLabel"
                font="font:SmallSystemFont"
                color="#EF4444"
                width="700"
                translation="[0, 210]"
            />

            <!-- Description -->
            <Label
                id="descLabel"
                font="font:MediumSystemFont"
                color="#CCCCCC"
                width="700"
                maxLines="5"
                wrap="true"
                translation="[0, 250]"
            />

            <!-- Cast section -->
            <Group id="castSection" translation="[0, 420]">
                <Label
                    id="castHeader"
                    text="CAST"
                    font="font:SmallestBoldSystemFont"
                    color="#666666"
                />
                <Label
                    id="castLabel"
                    font="font:SmallSystemFont"
                    color="#A0A0A0"
                    width="700"
                    maxLines="2"
                    wrap="true"
                    translation="[0, 35]"
                />
            </Group>

            <!-- Director section -->
            <Group id="directorSection" translation="[0, 530]">
                <Label
                    id="directorHeader"
                    text="DIRECTOR"
                    font="font:SmallestBoldSystemFont"
                    color="#666666"
                />
                <Label
                    id="directorLabel"
                    font="font:SmallSystemFont"
                    color="#A0A0A0"
                    translation="[0, 35]"
                />
            </Group>

            <!-- ============================================= -->
            <!-- ACTION BUTTONS (for unlocked content) -->
            <!-- ============================================= -->
            <Group id="buttonGroup" translation="[0, 610]" visible="true">
                <LayoutGroup
                    id="buttonRow"
                    layoutDirection="horiz"
                    itemSpacings="[20]"
                >
                    <!-- Play button -->
                    <Rectangle id="playBtnBg" width="220" height="56" color="#EF4444">
                        <Label
                            id="playBtnLabel"
                            text="▶ PLAY"
                            font="font:MediumBoldSystemFont"
                            color="#EBEBEB"
                            width="220"
                            height="56"
                            horizAlign="center"
                            vertAlign="center"
                        />
                    </Rectangle>
                    
                    <!-- Resume button (shown if progress exists) -->
                    <Rectangle id="resumeBtnBg" width="180" height="56" color="#333333" visible="false">
                        <Label
                            id="resumeBtnLabel"
                            text="RESUME"
                            font="font:SmallBoldSystemFont"
                            color="#EBEBEB"
                            width="180"
                            height="56"
                            horizAlign="center"
                            vertAlign="center"
                        />
                    </Rectangle>
                </LayoutGroup>
            </Group>

            <!-- ============================================= -->
            <!-- PAYWALL (for locked content) -->
            <!-- ============================================= -->
            <Group id="paywallGroup" translation="[0, 580]" visible="false">
                <!-- Lock message -->
                <Label
                    id="lockMessage"
                    text="This content requires purchase"
                    font="font:MediumBoldSystemFont"
                    color="#EBEBEB"
                    width="700"
                />

                <!-- QR Code -->
                <Group id="qrSection" translation="[0, 50]">
                    <Rectangle
                        id="qrBg"
                        width="160"
                        height="160"
                        color="#EBEBEB"
                    />
                    <Poster
                        id="qrCode"
                        width="140"
                        height="140"
                        translation="[10, 10]"
                    />
                    
                    <Group translation="[180, 10]">
                        <Label
                            id="scanLabel"
                            text="SCAN TO UNLOCK"
                            font="font:SmallBoldSystemFont"
                            color="#EF4444"
                        />
                        <Label
                            id="priceLabel"
                            font="font:MediumBoldSystemFont"
                            color="#EBEBEB"
                            translation="[0, 35]"
                        />
                        <Label
                            id="urlLabel"
                            font="font:SmallSystemFont"
                            color="#A0A0A0"
                            width="400"
                            maxLines="2"
                            wrap="true"
                            translation="[0, 75]"
                        />
                    </Group>
                </Group>
            </Group>
        </Group>

        <!-- Watch Party indicator -->
        <Group id="watchPartyBanner" translation="[1480, 40]" visible="false">
            <Rectangle
                width="350"
                height="50"
                color="#EF4444"
            />
            <Label
                text="🔴 LIVE WATCH PARTY"
                font="font:SmallBoldSystemFont"
                color="#EBEBEB"
                width="350"
                height="50"
                horizAlign="center"
                vertAlign="center"
            />
        </Group>

        <!-- Focus indicator -->
        <Rectangle
            id="focusIndicator"
            width="228"
            height="64"
            translation="[86, 656]"
            color="#00000000"
            visible="false"
        >
            <Rectangle width="228" height="3" color="#EBEBEB" translation="[0, 0]" />
            <Rectangle width="228" height="3" color="#EBEBEB" translation="[0, 61]" />
            <Rectangle width="3" height="64" color="#EBEBEB" translation="[0, 0]" />
            <Rectangle width="3" height="64" color="#EBEBEB" translation="[225, 0]" />
        </Rectangle>
    </children>
</component>
