<?xml version="1.0" encoding="utf-8" ?>
<!--
    CRATE TV - Home Scene (V4 Studio)
    
    - Hero spotlight: 1740x675 cinematic poster + info panel
    - REMOVED: "Press OK to Play" overlay (user found it cluttered)
    - RowList: LargeBoldSystemFont row headers, dynamic from API titles
    - Focus: 6px red border + 1.1x scale on posters
-->
<component name="HomeScene" extends="Group">
    <interface>
        <field id="selectedContent" type="node" alwaysNotify="true" />
        <field id="playContent" type="node" alwaysNotify="true" />
        <field id="exitRequested" type="boolean" value="false" alwaysNotify="true" />
        <field id="deepLinkContentId" type="string" value="" />
        <field id="focusedContent" type="node" />
        <field id="feedDataReady" type="node" alwaysNotify="true" />
    </interface>

    <script type="text/brightscript" uri="pkg:/source/Config.brs" />
    <script type="text/brightscript" uri="pkg:/source/ResolutionManager.brs" />
    <script type="text/brightscript" uri="HomeScene.brs" />

    <children>
        <!-- HERO CYCLING TIMER -->
        <Timer id="heroTimer" duration="8" repeat="true" />

        <!-- BACKGROUND -->
        <Rectangle id="bgRect" width="1920" height="1080" color="#050505" />
        <Poster id="dynamicBackdrop" width="1920" height="1080" loadWidth="1920" loadHeight="1080" loadDisplayMode="scaleToFill" loadingBitmapOpacity="0.0" failedBitmapOpacity="0.0" opacity="0.3" />

        <!-- ============================================================ -->
        <!-- HERO SPOTLIGHT (1740 x 675) -->
        <!-- ============================================================ -->
        <Group id="heroSpotlight" translation="[90, 10]" visible="false">
            <Rectangle id="heroCardBg" width="1740" height="675" color="#0A0A0A" opacity="0.85" />

            <!-- Poster (left) -->
            <Rectangle id="heroPosterBg" width="430" height="645" color="#1A1A1A" translation="[15, 15]" />
            <Poster id="heroPosterImage" width="430" height="645" loadWidth="430" loadHeight="645" loadDisplayMode="scaleToFill" loadingBitmapOpacity="0.0" failedBitmapUri="pkg:/images/poster_placeholder.png" translation="[15, 15]" />
            <!-- Rounded corner mask for hero poster -->
            <Poster id="heroPosterCornerMask" width="430" height="645" uri="pkg:/images/corner_mask_430x645.png" translation="[15, 15]" />

            <!-- Accent divider -->
            <Rectangle id="accentLine" width="4" height="615" color="#EF4444" translation="[470, 30]" />

            <!-- Info (right) -->
            <Group id="heroInfo" translation="[500, 25]">
                <Label id="heroTitle" text="" font="font:LargeBoldSystemFont" color="#EBEBEB" width="1200" maxLines="2" wrap="true" translation="[0, 0]" />
                <Label id="heroMeta" text="" font="font:SmallSystemFont" color="#A0A0A0" width="1200" translation="[0, 85]" />
                <Label id="heroGenre" text="" font="font:SmallSystemFont" color="#EF4444" width="1200" translation="[0, 115]" />
                <Label id="heroDesc" text="" font="font:SmallSystemFont" color="#CCCCCC" width="1200" maxLines="5" wrap="true" translation="[0, 155]" />

                <!-- CAST (y=400) -->
                <Group id="heroCastSection" translation="[0, 400]" visible="false">
                    <Label id="heroCastHeader" text="CAST" font="font:SmallBoldSystemFont" color="#999999" />
                    <Label id="heroCastLabel" font="font:SmallSystemFont" color="#A0A0A0" width="1200" maxLines="1" translation="[0, 28]" />
                </Group>

                <!-- DIRECTOR (y=470 -- 70px clear of cast) -->
                <Group id="heroDirectorSection" translation="[0, 470]" visible="false">
                    <Label id="heroDirectorHeader" text="DIRECTOR" font="font:SmallBoldSystemFont" color="#999999" />
                    <Label id="heroDirectorLabel" font="font:SmallSystemFont" color="#A0A0A0" width="1200" maxLines="1" translation="[0, 28]" />
                </Group>

                <!-- NO "Press OK to Play" -- REMOVED per user request -->
                <!-- NO Watch Party badge -- REMOVED per user request -->
            </Group>
        </Group>

        <!-- ============================================================ -->
        <!-- ROW LIST -- LargeBoldSystemFont for massive row headers -->
        <!-- Crate Standard: 240x360 with custom focus ring only -->
        <!-- ============================================================ -->
        <RowList
            id="rowList"
            translation="[0, 710]"
            itemSize="[1920, 490]"
            itemSpacing="[0, 40]"
            showRowLabel="[true]"
            showRowCounter="[false]"
            rowLabelOffset="[[90, 20]]"
            rowLabelColor="#EBEBEB"
            rowLabelFont="font:LargeBoldSystemFont"
            focusXOffset="[90]"
            drawFocusFeedback="false"
            vertFocusAnimationStyle="floatingFocus"
            rowFocusAnimationStyle="floatingFocus"
            visible="false"
        />

        <!-- LOADING STATE -->
        <Group id="loadingGroup" visible="true">
            <Rectangle width="1920" height="1080" color="#050505" />
            <Group translation="[760, 520]">
                <Rectangle id="loadingBar" width="400" height="4" color="#333333" />
                <Rectangle id="loadingProgress" width="100" height="4" color="#EF4444" />
                <Label id="loadingText" text="Loading your experience..." font="font:SmallSystemFont" color="#A0A0A0" width="400" horizAlign="center" translation="[0, 24]" />
            </Group>
        </Group>

        <!-- ERROR STATE -->
        <Group id="errorGroup" visible="false">
            <Rectangle width="1920" height="1080" color="#050505" />
            <Group translation="[560, 380]">
                <Label id="errorIcon" text="⚠" font="font:LargeBoldSystemFont" color="#EF4444" width="800" horizAlign="center" />
                <Label id="errorTitle" text="Something went wrong" font="font:LargeBoldSystemFont" color="#EBEBEB" width="800" horizAlign="center" translation="[0, 80]" />
                <Label id="errorMessage" text="Unable to load content." font="font:MediumSystemFont" color="#A0A0A0" width="800" horizAlign="center" wrap="true" translation="[0, 150]" />
                <Rectangle id="retryBtn" width="200" height="50" color="#EF4444" translation="[300, 250]">
                    <Label text="TRY AGAIN" font="font:SmallBoldSystemFont" color="#EBEBEB" width="200" height="50" horizAlign="center" vertAlign="center" />
                </Rectangle>
            </Group>
        </Group>
    </children>
</component>
