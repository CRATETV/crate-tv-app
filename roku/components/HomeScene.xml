<?xml version="1.0" encoding="utf-8" ?>
<component name="HomeScene" extends="Group">
    <interface>
        <field id="content"   type="node" onChange="onContentChange" />
        <field id="heroItems" type="node" onChange="onHeroItemsChange" />
        <field id="command"   type="assocarray" alwaysNotify="true" />
    </interface>
    <script type="text/brightscript" uri="pkg:/components/HomeScene.brs" />
    <children>

        <!-- ── HERO SECTION ───────────────────────────────────────── -->
        <Group id="hero">
            <!-- Wide hero image — uses heroImage field (1920x800), falls back to hdPosterUrl -->
            <Poster
                id="heroImage"
                width="1920"
                height="800"
                loadDisplayMode="scaleToFill"
            />

            <!-- Cinematic gradient overlays — matches web app -->
            <!-- Left vignette — darkens text area -->
            <Rectangle
                width="1100" height="800"
                color="0x050505FF"
                gradientDirection="left-to-right"
                endColor="0x00000000"
            />
            <!-- Bottom blend — rows emerge from hero -->
            <Rectangle
                width="1920" height="500"
                translation="[0, 300]"
                color="0x050505FF"
                gradientDirection="bottom-to-top"
                endColor="0x00000000"
            />

            <!-- Hero content — left-aligned like the web app -->
            <Group id="heroContent" translation="[100, 120]">

                <!-- Red badge — SPOTLIGHT or LIVE or NEW -->
                <Rectangle id="heroBadgeBg" width="220" height="36" color="0xEF4444FF">
                    <Label id="heroBadge"
                        text="SPOTLIGHT SELECTION"
                        width="220" height="36"
                        horizAlign="center" vertAlign="center"
                        font="font:SmallestBoldSystemFont"
                        color="0xFFFFFFFF"
                    />
                </Rectangle>

                <!-- Film title — large, bold, italic like web -->
                <Label id="heroTitle"
                    translation="[0, 50]"
                    width="900"
                    wrap="true"
                    maxLines="2"
                    color="0xFFFFFFFF"
                >
                    <font role="sans" size="90" weight="bold" />
                </Label>

                <!-- Director line -->
                <Label id="heroDirector"
                    translation="[0, 230]"
                    width="700"
                    font="font:SmallSystemFont"
                    color="0x888888FF"
                />

                <!-- Synopsis — matches web line clamp -->
                <Label id="heroSynopsis"
                    translation="[0, 280]"
                    width="800"
                    wrap="true"
                    maxLines="3"
                    font="font:MediumSystemFont"
                    color="0xCCCCCCFF"
                />

                <!-- Action buttons -->
                <Rectangle id="playBtn"
                    translation="[0, 480]"
                    width="220" height="72"
                    color="0xFFFFFFFF"
                >
                    <Label text="▶  PLAY"
                        width="220" height="72"
                        horizAlign="center" vertAlign="center"
                        color="0x000000FF"
                        font="font:SmallBoldSystemFont"
                    />
                </Rectangle>

                <Rectangle id="infoBtn"
                    translation="[240, 480]"
                    width="220" height="72"
                    color="0x33333388"
                >
                    <Label text="ⓘ  DETAILS"
                        width="220" height="72"
                        horizAlign="center" vertAlign="center"
                        color="0xFFFFFFFF"
                        font="font:SmallBoldSystemFont"
                    />
                </Rectangle>
            </Group>

            <!-- Hero dot pagination -->
            <Group id="heroDots" translation="[100, 750]" />
        </Group>

        <!-- ── CONTENT ROWS ────────────────────────────────────────── -->
        <RowList
            id="rowList"
            translation="[0, 635]"
            itemComponentName="MoviePosterItem"
            itemSize="[1920, 445]"
            rowHeights="[445]"
            rowItemSize="[ [270, 405] ]"
            rowItemSpacing="[ [30, 0] ]"
            rowLabelOffset="[ [100, 20] ]"
            focusXOffset="[ 100 ]"
            rowFocusAnimationStyle="floatingFocus"
        />

        <!-- ── HERO TRAILER ────────────────────────────────────────── -->
        <!-- Plays after 1s dwell, muted, 30s max — identical to web -->
        <Video
            id="heroTrailer"
            width="1920"
            height="800"
            visible="false"
            mute="true"
            loop="true"
        />

        <Timer id="trailerTimer"     repeat="false" duration="1" />
        <Timer id="trailerStopTimer" repeat="false" duration="30" />
        <Timer id="heroRotateTimer"  repeat="true"  duration="8" />

    </children>
</component>
