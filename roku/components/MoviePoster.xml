
<?xml version="1.0" encoding="utf-8" ?>
<component name="MoviePoster" extends="Group">

    <script type="text/brightscript" uri="pkg:/components/MoviePoster.brs" />

    <interface>
        <field id="itemContent" type="node" onChange="onContentChange" />
        <field id="focusPercent" type="float" onChange="onFocusChange" />
    </interface>

    <children>
        <!-- V4 Snug Focus Ring: 4px border logic (Poster 270x405 + 8px = 278x413) -->
        <Rectangle 
            id="focusRing"
            color="0xEF4444FF"
            width="278"
            height="413"
            translation="[-4, -4]"
            visible="false"
        />
        
        <Poster 
            id="tilePoster"
            width="270"
            height="405"
            loadDisplayMode="scaleToFill"
        />

        <Label
            id="titleLabel"
            width="270"
            translation="[0, 415]"
            font="font:ExtraSmallBoldSystemFont"
            color="0x888888FF"
            visible="false"
        />
    </children>

</component>
