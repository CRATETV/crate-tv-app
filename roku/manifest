##############################################################################
# CRATE TV - Roku Channel Manifest (CERTIFICATION READY 2025)
# Production-Ready VOD Streaming Platform
##############################################################################

# Channel Properties
title=Crate TV
major_version=2
minor_version=1
build_version=1

# SceneGraph Application
mm_icon_focus_fhd=pkg:/images/channel_logo_fhd.png
mm_icon_side_fhd=pkg:/images/channel_logo_side_fhd.png
mm_icon_focus_hd=pkg:/images/channel_logo_hd.png
mm_icon_focus_sd=pkg:/images/channel_logo_sd.png
splash_screen_fhd=pkg:/images/splash_fhd.png
splash_screen_hd=pkg:/images/splash_hd.png
splash_screen_sd=pkg:/images/splash_sd.png
splash_color=#050505
splash_min_time=2000

# UI Resolution
ui_resolutions=fhd,hd

# ==============================================================================
# DEEP LINKING SUPPORT (CRITICAL FOR CERTIFICATION)
# ==============================================================================
# Enables deep linking from Roku Search, voice commands, and external launches
supports_input_launch=1

# ==============================================================================
# ROKU SEARCH INTEGRATION (GLOBAL SEARCH READY)
# ==============================================================================
# Enables your content to appear in Roku's universal search
# Your backend must implement the Roku Search Feed format
supports_search=1

# ==============================================================================
# PERFORMANCE BEACON (ANALYTICS & MONITORING)
# ==============================================================================
# Allows Roku to track app performance metrics
# Required for proper AppLaunchComplete signaling
bs_libs_required=roku_ads_lib

# ==============================================================================
# PLAYBACK FEATURES
# ==============================================================================
# Allows partner button remapping (for branded remote controls)
confirm_partner_button=1

# ==============================================================================
# PERFORMANCE & OPTIMIZATION
# ==============================================================================
# Enables advanced graphics settings for better performance
supports_graphicsSettings=1

# Thread-safe access to registry (recommended for production)
thread_safe_registry=1

# ==============================================================================
# OPTIONAL: SCREENSAVER SUPPORT
# ==============================================================================
# Uncomment to enable custom screensaver (requires implementation)
# screensaver_title=Crate TV Screensaver
# screensaver_private=1
