rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Fields that ONLY the server (Admin SDK) can write.
    // unlockedBlocks is intentionally NOT in this list — free blocks
    // need client-side writes, and paid blocks are validated server-side
    // before the client's unlockFestivalBlock() call is made.
    function isWritingProtectedFields() {
      let protectedFields = [
        'hasFestivalAllAccess',
        'hasCrateFestPass',
        'hasJuryPass',
        'isPremiumSubscriber',
        'purchasedMovieKeys',
      ];
      return request.resource.data.diff(resource.data).affectedKeys().hasAny(protectedFields);
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow update: if isOwner(uid) && !isWritingProtectedFields();
      allow create: if isOwner(uid) && !isWritingProtectedFields();
      allow delete: if false;
    }

    match /festival_tickets/{ticketId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    match /watch_parties/{partyId} {
      allow read: if isSignedIn();
      allow write: if false;

      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() <= 500;
        allow update, delete: if false;
      }

      match /live_reactions/{reactionId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if false;
      }
    }

    match /festival_viewers/{viewerId} {
      allow read: if false;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    match /promo_codes/{codeId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /pwff_invites/{email} {
      allow read: if isSignedIn() && request.auth.token.email == email;
      allow write: if false;
    }

    match /movies/{movieId} {
      allow read: if true;
      allow write: if false;
    }

    match /categories/{catId} {
      allow read: if true;
      allow write: if false;
    }

    match /content/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /data/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /festival/{docId} {
      allow read: if true;
      allow write: if false;

      match /{subcollection}/{subDocId} {
        allow read: if true;
        allow write: if false;
      }
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /view_counts/{docId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    match /movie_pipeline/{submissionId} {
      allow read: if isSignedIn() && (resource == null || resource.data.submitterUid == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.submitterUid == request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
