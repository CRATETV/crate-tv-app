rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ───────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // CRITICAL: These fields control access to paid content.
    // Clients must NEVER be allowed to write these themselves —
    // only the server (via Admin SDK) can grant access after payment verification.
    function isWritingPaymentFields() {
      let paymentFields = [
        'hasFestivalAllAccess',
        'hasCrateFestPass',
        'hasJuryPass',
        'isPremiumSubscriber',
        'unlockedBlocks',
        'unlockedBlockIds',
        'rentals',
        'unlockedWatchPartyKeys',
        'purchasedMovieKeys',
      ];
      return request.resource.data.diff(resource.data).affectedKeys().hasAny(paymentFields);
    }

    // ── Users collection ───────────────────────────────────────────────────
    match /users/{uid} {
      // Users can read their own profile
      allow read: if isOwner(uid);

      // Users can update their own profile BUT cannot touch payment/access fields
      // Payment fields are only written by the server via Admin SDK after payment
      allow update: if isOwner(uid) && !isWritingPaymentFields();

      // Only server can create user docs (via Admin SDK on registration)
      allow create: if isOwner(uid) && !isWritingPaymentFields();

      // Nobody can delete user docs from the client
      allow delete: if false;
    }

    // ── Festival tickets — read-only for owners, write only by server ──────
    match /festival_tickets/{ticketId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow write: if false; // Server-only via Admin SDK after Square payment
    }

    // ── Watch parties — participants can read, only server writes state ─────
    match /watch_parties/{partyId} {
      allow read: if isSignedIn();
      // Server controls party state (start/stop/advance)
      // Clients should NOT be able to flip status to 'live' themselves
      allow write: if false;

      // Chat messages — authenticated users can post
      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() <= 500;
        allow update, delete: if false;
      }

      // Live reactions — anyone signed in can post briefly
      match /live_reactions/{reactionId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if false;
      }
    }

    // ── Festival viewer tracking ───────────────────────────────────────────
    match /festival_viewers/{viewerId} {
      allow read: if false; // Admin only
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // ── Promo codes — readable by signed-in users (to validate), server writes ─
    match /promo_codes/{codeId} {
      allow read: if isSignedIn();
      allow write: if false; // Server-only
    }

    // ── PWFF invites — server-only ─────────────────────────────────────────
    match /pwff_invites/{email} {
      allow read: if isSignedIn()
        && request.auth.token.email == email;
      allow write: if false; // Server-only
    }

    // ── Public content (movies, categories, settings) — read-only ─────────
    match /movies/{movieId} {
      allow read: if true; // Public catalog
      allow write: if false; // Admin SDK only
    }

    match /categories/{catId} {
      allow read: if true;
      allow write: if false;
    }

    match /content/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /data/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Festival schedule — public read ───────────────────────────────────
    match /festival/{docId} {
      allow read: if true;
      allow write: if false;

      match /schedule/days/{dayId} {
        allow read: if true;
        allow write: if false;
      }

      match /{subcollection}/{docId} {
        allow read: if true;
        allow write: if false;
      }
    }

    // ── Settings — public read ────────────────────────────────────────────
    match /settings/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ── View counts — public read, signed-in write ────────────────────────
    match /view_counts/{docId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    // ── Film submissions — filmmaker can create/read their own ────────────
    match /movie_pipeline/{submissionId} {
      allow read: if isSignedIn()
        && (resource == null || resource.data.submitterUid == request.auth.uid);
      allow create: if isSignedIn()
        && request.resource.data.submitterUid == request.auth.uid;
      allow update: if false; // Admin only after submission
      allow delete: if false;
    }

    // ── Everything else — deny by default ─────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
