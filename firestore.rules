rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isWritingProtectedFields() {
      let protectedFields = [
        'hasFestivalAllAccess',
        'hasCrateFestPass',
        'hasJuryPass',
        'isPremiumSubscriber',
        'purchasedMovieKeys',
        // These four grant access to paid content (movie rentals, watch party
        // tickets, festival block unlocks, and legacy block-unlock formats)
        // and were previously writable by clients directly — meaning anyone
        // with browser devtools could grant themselves any paid movie or
        // watch party for free by writing straight to their own user doc.
        // Access to these is now only ever granted server-side (Admin SDK,
        // which bypasses these rules) after a verified payment or a verified
        // ticket-code redemption — see api/process-square-payment.ts and
        // api/redeem-ticket-code.ts.
        'rentals',
        'unlockedWatchPartyKeys',
        'unlockedBlocks',
        'unlockedBlockIds',
        'unlockedFestivalDays',
      ];
      return request.resource.data.diff(resource.data).affectedKeys().hasAny(protectedFields);
    }

    // ── Users ──────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isOwner(uid);
      allow update: if isOwner(uid) && !isWritingProtectedFields();
      allow create: if isOwner(uid) && !isWritingProtectedFields();
      allow delete: if false;
    }

    // ── Watch parties — all subcollections allowed for signed-in users ─
    match /watch_parties/{partyId} {
      allow read: if isSignedIn();
      allow write: if false; // server only

      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() <= 500;
        allow update, delete: if false;
      }

      match /live_reactions/{reactionId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if false;
      }

      // Lobby viewers tracking — who is in the lobby waiting
      match /lobby_viewers/{viewerId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn();
        allow delete: if isSignedIn();
      }
    }

    // ── Festival viewers log ───────────────────────────────────────────
    match /festival_viewers/{viewerId} {
      allow read: if false; // admin only
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if false;
    }

    // ── Festival tickets ───────────────────────────────────────────────
    match /festival_tickets/{ticketId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow write: if false; // server only
    }

    // ── Promo codes ────────────────────────────────────────────────────
    match /promo_codes/{codeId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ── PWFF invites ───────────────────────────────────────────────────
    match /pwff_invites/{email} {
      allow read: if isSignedIn() && request.auth.token.email == email;
      allow write: if false;
    }

    // ── Public content ─────────────────────────────────────────────────
    match /movies/{movieId} {
      allow read: if true;
      allow write: if false;
    }

    match /categories/{catId} {
      allow read: if true;
      allow write: if false;
    }

    match /content/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /data/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /festival/{docId} {
      allow read: if true;
      allow write: if false;
      match /{subcollection}/{subDocId} {
        allow read: if true;
        allow write: if false;
      }
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ── View counts ────────────────────────────────────────────────────
    match /view_counts/{docId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    // ── Watch party schedule (public) ──────────────────────────────────
    match /watch_party_schedule/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Film submissions ────────────────────────────────────────────────
    match /movie_pipeline/{submissionId} {
      allow read: if isSignedIn()
        && (resource == null || resource.data.submitterUid == request.auth.uid);
      allow create: if isSignedIn()
        && request.resource.data.submitterUid == request.auth.uid;
      allow update, delete: if false;
    }

    // ── Deny everything else ───────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
